#######################
# Eclipse / Java Setup
#######################

# --- Keep these tracked so projects import cleanly ---
!.project
!.classpath
!.settings/
!.settings/org.eclipse.jdt.core.prefs
!.settings/org.eclipse.jdt.ui.prefs

# --- Ignore Eclipse workspace cruft ---
.metadata/
.recommenders/
.loadpath

# --- Ignore build outputs ---
bin/
out/
target/
tmp/
*.tmp
*.bak
*.swp

# --- Ignore launch configs (often machine-specific) ---
*.launch

#######################
# Other IDEs (optional)
#######################
.idea/
.vscode/

#######################
# OS cruft
#######################
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
